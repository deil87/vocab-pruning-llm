    static_results.append(r)
    print(f"  Acceptance: {r['acceptance_rate']:.3f}  PPL: {r['perplexity']:.3f}  ΔPPL: {r['delta_ppl']:+.3f}  TPS: {r['tokens_per_sec']:.2f}")

